# === LLM ===
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxx

# === Qdrant ===
# Leave empty to use in-memory mode (no external Qdrant needed)
QDRANT_URL=
QDRANT_API_KEY=

# === Embedding Model ===
# Options: BAAI/bge-large-en-v1.5 (1024d, ~1.3GB) or BAAI/bge-small-en-v1.5 (384d, ~130MB)
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# === LangSmith (optional) ===
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=hiremind
LANGCHAIN_TRACING_V2=false

# === App ===
DEMO_MODE=true

# Alternative LLM Providers
GROQ_API_KEY=
GEMINI_API_KEY=
